# Copy to vault/integrations.env (create vault/ if needed). File is gitignored.
# Vite dev/preview merges this into process.env (see vite.config.ts).

# --- Mailchimp (Marketing API — audience upserts from forms)
MAILCHIMP_API_KEY=your_key_with_datacenter_suffix
MAILCHIMP_SERVER_PREFIX=us20
# Mailchimp → Audience → Settings → Audience name and defaults → Audience ID (hex string)
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_MEMBER_STATUS=subscribed

# --- Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Optional: API Key auth instead of Auth Token for REST
# TWILIO_API_KEY_SID=
# TWILIO_API_KEY_SECRET=

# Required for sending: E.164 from number OR Messaging Service SID
TWILIO_FROM_NUMBER=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
# TWILIO_PREQUAL_SMS_BODY=
