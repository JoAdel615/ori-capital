{
  "name": "ori-capital",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-vite-ports.mjs && vite",
    "dev:v2": "vite --port 5174 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "integrations:check": "node scripts/check-integration-env.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "node scripts/kill-vite-ports.mjs && vite preview",
    "api": "tsx server/apiServer.ts",
    "api:cpanel": "node server/cpanel-entry.cjs",
    "deploy:cpanel": "npm run build && node scripts/deploy-cpanel.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "screenshots:export": "npm run build && sh -c 'npx vite preview --port 4173 --strictPort & PID=$!; sleep 4; node scripts/screenshots.mjs https://localhost:4173; kill \"$PID\" 2>/dev/null || true'"
  },
  "dependencies": {
    "tsx": "^4.21.0",
    "framer-motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "undici": "^7.24.7",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
