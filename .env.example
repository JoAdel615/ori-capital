# Ori Capital — Environment template
# Copy to .env and fill in values. Never commit .env.

# --- Back Office (Vite dev / preview middleware; server-only, not exposed to client)
# Password for /api/admin/login and Bearer token issuance. Defaults to "admin" if unset when NODE_ENV is not production.
# In production (e.g. vite preview with NODE_ENV=production), require min 16 chars and not the word "admin", unless:
# BACKOFFICE_RELAX_AUTH=1
# BACKOFFICE_ADMIN_PASSWORD=
# BACKOFFICE_RELAX_AUTH=
# Standalone API (npm run api / cPanel Node): browser CORS — exact site origin, e.g. https://oricapitalholdings.com
# API_CORS_ORIGIN=
# PORT=8787
# NODE_ENV=production
# Behind a trusted reverse proxy only: use X-Forwarded-For for rate-limit IP keys (default: direct socket only).
# TRUST_X_FORWARDED_FOR=1
# Public site origin for partner referral links and invite URLs (e.g. https://oricapital.com)
# SITE_PUBLIC_URL=http://localhost:5173

# --- Testimonials (client; optional)
# VITE_TESTIMONIAL_REQUEST_EMAIL=hello@oricapital.com

# --- Integrations (optional; see server/integrations/index.ts)
# Credit Repair Cloud (Developer API — keep in local .env only; never commit real keys)
# CRC_API_KEY=
# CRC_SECRET_KEY=
# MAILCHIMP_API_KEY=
# MAILCHIMP_SERVER_PREFIX=
# Audience / list ID (required for audience upserts from forms)
# MAILCHIMP_AUDIENCE_ID=
# subscribed | pending (double opt-in) | transactional
# MAILCHIMP_MEMBER_STATUS=subscribed
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# Send SMS: set TWILIO_FROM_NUMBER (+E.164) and/or TWILIO_MESSAGING_SERVICE_SID=MG...
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=
# Optional copy for prequal SMS opt-in confirmation
# TWILIO_PREQUAL_SMS_BODY=
# Optional API key auth (see vault/README.md): TWILIO_API_KEY_SID=, TWILIO_API_KEY_SECRET=
# Prefer secrets in vault/integrations.env (gitignored); vite.config merges it for dev/preview.
# Full template: integrations.vault.example — verify with: npm run integrations:check
# CALENDLY_INTEGRATION_ENABLED=false
# Calendly Personal Access Token (server-side API only; keep in vault, never in VITE_* or client code)
# CALENDLY_TOKEN=
# Public scheduling URL for website embeds (safe in frontend). Example: https://calendly.com/your-org/consultation
# VITE_CALENDLY_URL=

# --- Frontend (Vite; exposed at build time, do not put secrets here)
# When the site is static (cPanel) and APIs run elsewhere:
# VITE_API_ORIGIN=https://api.oricapitalholdings.com
# VITE_APPLY_API_URL=
# VITE_APPLY_EXTERNAL_URL=
# VITE_CAPITAL_PARTNERS_API_URL=
# VITE_NEWSLETTER_API_URL=
# VITE_STRATEGY_CALL_URL=
# VITE_SITE_URL=
# Optional: POST JSON client error payloads from the in-app error boundary (CORS must allow your origin).
# VITE_CLIENT_ERROR_REPORT_URL=
# GA4 (public; format G-XXXXXXXX). Optional.
# VITE_GA_MEASUREMENT_ID=
# Meta Pixel (public; numeric ID). Optional.
# VITE_META_PIXEL_ID=

# --- eCrypt (Transaction Gateway) — see integration portal
# Private API security key (Payment API transact.php). NEVER expose to the browser. Settings → Security Keys.
ECRYPT_API_KEY=your_ecrypt_security_key_here
# Optional: on approved sale, also add card to Customer Vault (requires vault on your account). Values: true | false
# ECRYPT_CUSTOMER_VAULT=true

# Optional only if using Collect.js (NOT required for Three-Step Redirect flow).
# VITE_ECRYPT_TOKENIZATION_KEY=your_collect_js_tokenization_key_here

# --- Sandbox / test charges (Payment API)
# One-off test transactions: sends test_mode=enabled on each /api/payments/charge. Use gateway test cards + exp 10/25 (1025).
# Remove or set false for live card processing.
# ECRYPT_TEST_MODE=true

# Official test cards (same as integration portal “Test Data”): Visa 4111111111111111, MC 5431111111111111,
# Discover 6011000991300009, Amex 341111111111111 — expiration 10/25, CVV often 999 for CVV-match simulation.
# Full account test mode: Gateway Options → Test Mode in https://ecrypt.transactiongateway.com
